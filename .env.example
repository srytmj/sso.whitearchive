APP_NAME="SSO Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sso.suryatmaja.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_READ_HOST=127.0.0.1
DB_WRITE_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_sso
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@suryatmaja.dev"
MAIL_FROM_NAME="SSO whitearchive.id"

RESEND_API_KEY=re_***

VITE_APP_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@suryatmaja.dev
ADMIN_PASSWORD=change-me-in-production
